    ],
    
    (* Entanglement Monad in Kleisli Category *)
    ūĚďĒ_monad = Monad[
      Functor ‚Üí T: ūĚď£ ‚Üí ūĚď£,
      T[X] = X ‚äó_‚Ą§/2‚Ą§ Antipode[X],
      Unit ‚Üí ő∑: Id ‚áí T,
      ő∑_X = diagonal: X ‚Üí X √ó X ‚Üí X ‚äó Antipode[X],
      Multiplication ‚Üí őľ: T‚ąėT ‚áí T,
      őľ_X = projection: (X‚äóXŐĄ)‚äó(X‚äóXŐĄ) ‚Üí X‚äóXŐĄ,
      
