  "theory": {
    "canonical_statement": "To map an $n\\times m$ real matrix $B$ to a DAANSphere address:",
    "technical_interpretation": "To map an $n\\times m$ real matrix $B$ to a DAANSphere address: \\[ B = U\\Sigma V^{T}. \\] Extract the first three left singular vectors $u_1,u_2,u_3$ and normalize them to points on $S^2$. Convert the corresponding angles to continued-fraction expansions, multiply each coefficient by $\\pi^{p/2}$ at the desired precision, and extract base-3 digits. Apply the Cantor pairing function recursively to collapse the digit sequence to a single integer modulo $153{,}600$, select a tesseract vertex from the lower four bits, combine the vertex and Cantor encodings, and prepare the 18-qubit state defined by the 18-bit binary representation of the resulting address."
  },
  "canonical_equation": {
    "latex_blocks": [
      "B = U\\Sigma V^{T}.",
      "B=U\\Sigma V^{\\top}",
      "A_{\\mathrm{DAQ}}=\\bigl(\\pi_C(d_1,\\ldots,d_k)\\bmod 153600\\bigr)+1"
    ],
    "source_section_latex": "\\[ B = U\\Sigma V^{T}. \\] Extract the first three left singular vectors $u_1,u_2,u_3$ and normalize them to points on $S^2$. Convert the corresponding angles to continued-fraction expansions, multiply each coefficient by $\\pi^{p/2}$ at the desired precision, and extract base-3 digits. Apply the Cantor pairing function recursively to collapse the digit sequence to a single integer modulo $153{,}600$, select a tesseract vertex from the lower four bits, combine the vertex and Cantor encodings, and prepare the 18-qubit state defined by the 18-bit binary representation of the resulting address.\n\n\\[\nB=U\\Sigma V^{\\top}\n\\]\n\\[\nA_{\\mathrm{DAQ}}=\\bigl(\\pi_C(d_1,\\ldots,d_k)\\bmod 153600\\bigr)+1\n\\]"
  },
